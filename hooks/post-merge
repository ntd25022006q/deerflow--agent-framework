#!/bin/bash
# ═══════════════════════════════════════════════════════════════
# DEERFLOW POST-MERGE HOOK
# Re-verify quality after merge operations.
# Ensures merged code still meets Deerflow standards.
# ═══════════════════════════════════════════════════════════════

set -euo pipefail

# ─── Colors ───────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_pass() { echo -e "${GREEN}[PASS]${NC} $1"; }
log_fail() { echo -e "${RED}[FAIL]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_info() { echo -e "${BLUE}[MERGE]${NC} $1"; }

echo -e "${BLUE}╔══════════════════════════════════════════════════╗${NC}"
echo -e "${BLUE}║  🦌 DEERFLOW POST-MERGE QUALITY VERIFICATION     ║${NC}"
echo -e "${BLUE}╚══════════════════════════════════════════════════╝${NC}"
echo ""

ERRORS=0
ISSUES_FOUND=""

# ─── 1. Install dependencies if package.json changed ────────
if git diff --name-only HEAD@{1} HEAD 2>/dev/null | grep -q "package.json\|package-lock.json\|yarn.lock\|pnpm-lock.yaml"; then
  log_info "Dependencies changed — running install..."
  if [[ -f "package-lock.json" ]]; then
    npm install 2>&1 | tail -3 || true
  elif [[ -f "yarn.lock" ]]; then
    yarn install 2>&1 | tail -3 || true
  elif [[ -f "pnpm-lock.yaml" ]]; then
    pnpm install 2>&1 | tail -3 || true
  fi
  log_pass "Dependencies updated"
fi

# ─── 2. Type Check ───────────────────────────────────────────
log_info "Verifying TypeScript types..."
if command -v npx >/dev/null 2>&1 && [[ -f "tsconfig.json" ]]; then
  if npx tsc --noEmit 2>&1; then
    log_pass "TypeScript: no type errors"
  else
    log_fail "TypeScript: type errors found after merge"
    ERRORS=$((ERRORS + 1))
    ISSUES_FOUND="$ISSUES_FOUND\n  - TypeScript type errors"
  fi
fi

# ─── 3. Lint Check ───────────────────────────────────────────
log_info "Verifying code style..."
if command -v npx >/dev/null 2>&1; then
  if npx eslint . --ext .ts,.tsx,.js,.jsx --max-warnings=0 --quiet 2>&1; then
    log_pass "ESLint: no issues"
  else
    log_fail "ESLint: issues found after merge"
    ERRORS=$((ERRORS + 1))
    ISSUES_FOUND="$ISSUES_FOUND\n  - ESLint violations"
  fi
fi

# ─── 4. Test Suite ───────────────────────────────────────────
log_info "Running test suite..."
if command -v npx >/dev/null 2>&1; then
  if npx vitest run 2>&1; then
    log_pass "Tests: all passing"
  else
    log_fail "Tests: failures after merge"
    ERRORS=$((ERRORS + 1))
    ISSUES_FOUND="$ISSUES_FOUND\n  - Test failures"
  fi
fi

# ─── 5. Build Verification ───────────────────────────────────
if [[ -f "package.json" ]] && command -v jq >/dev/null 2>&1; then
  if jq -e '.scripts.build' package.json >/dev/null 2>&1; then
    log_info "Verifying build..."
    if npm run build 2>&1; then
      log_pass "Build: successful"
    else
      log_fail "Build: failed after merge"
      ERRORS=$((ERRORS + 1))
      ISSUES_FOUND="$ISSUES_FOUND\n  - Build failure"
    fi
  fi
fi

# ─── 6. Security Check ───────────────────────────────────────
log_info "Running security audit..."
if command -v npm >/dev/null 2>&1 && [[ -f "package.json" ]]; then
  if npm audit --audit-level=high 2>&1; then
    log_pass "Security: no high/critical vulnerabilities"
  else
    log_warn "Security: vulnerabilities detected — review npm audit output"
  fi
fi

# ─── 7. Architecture Check ───────────────────────────────────
log_info "Checking architecture integrity..."
if command -v npx >/dev/null 2>&1 && [[ -d "src" ]]; then
  if npx madge --circular --extensions ts,tsx src/ 2>/dev/null; then
    log_pass "Architecture: no circular dependencies"
  else
    log_warn "Architecture: circular dependencies detected"
  fi
fi

# ─── Summary ─────────────────────────────────────────────────
echo ""
if [[ "$ERRORS" -gt 0 ]]; then
  echo -e "${RED}╔══════════════════════════════════════════════════╗${NC}"
  echo -e "${RED}║  🦌 POST-MERGE: $ERRORS issue(s) detected            ║${NC}"
  echo -e "${RED}╠══════════════════════════════════════════════════╣${NC}"
  echo -e "${RED}║  Issues found:                                     ║${NC}"
  echo -e "${RED}$ISSUES_FOUND${NC}"
  echo -e "${RED}║                                                    ║${NC}"
  echo -e "${RED}║  Please fix these issues before continuing work.   ║${NC}"
  echo -e "${RED}║  Run: ./scripts/quality-check.sh --full           ║${NC}"
  echo -e "${RED}╚══════════════════════════════════════════════════╝${NC}"
  exit 1
else
  echo -e "${GREEN}╔══════════════════════════════════════════════════╗${NC}"
  echo -e "${GREEN}║  🦌 POST-MERGE: All quality checks passed ✓      ║${NC}"
  echo -e "${GREEN}║  Merge is clean — safe to continue development   ║${NC}"
  echo -e "${GREEN}╚══════════════════════════════════════════════════╝${NC}"
  exit 0
fi
